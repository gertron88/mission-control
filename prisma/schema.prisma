// Mission Control - Improved Database Schema
// Version 2.1 - Added performance indexes, soft deletes, and enhanced tracking

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// PORTFOLIO - Top-level strategic container
// ─────────────────────────────────────────────────────────────────────────────

model Portfolio {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique  // URL-friendly name
  description     String?  @db.Text
  
  // Strategy & Constraints
  strategy        String?  @db.Text
  budgetTotal     Decimal? @db.Decimal(12, 2)
  budgetUsed      Decimal  @default(0) @db.Decimal(12, 2)
  currency        String   @default("USD")
  priorities      Json?    // Priority scoring rules
  capacityRules   Json?    // Agent capacity allocation rules
  
  // Relations
  projects        Project[]
  
  // Metadata
  isActive        Boolean  @default(true)
  isArchived      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?  // User/agent who created
  
  @@index([isActive])
  @@index([slug])
  @@map("portfolios")
}

// ─────────────────────────────────────────────────────────────────────────────
// PROJECT - Individual managed initiative
// ─────────────────────────────────────────────────────────────────────────────

model Project {
  id              String   @id @default(cuid())
  portfolioId     String
  portfolio       Portfolio @relation(fields: [portfolioId], references: [id])
  
  // Identity
  name            String
  slug            String   @unique
  charter         String?  @db.Text
  description     String?  @db.Text
  
  // Objectives & Success
  objectives      Json?    // Array of objective objects
  successMetrics  Json?    // KPIs and targets
  
  // State Management
  state           ProjectState @default(PROPOSED)
  stateHistory    Json?    // Array of {state, timestamp, reason, actor}
  
  // Planning
  milestoneGraph  Json?    // DAG of milestones
  plannedStart    DateTime?
  plannedEnd      DateTime?
  actualStart     DateTime?
  actualEnd       DateTime?
  
  // Budget & Resources
  budgetAllocated Decimal? @db.Decimal(12, 2)
  budgetSpent     Decimal  @default(0) @db.Decimal(12, 2)
  effortEstimated Float?   // Person-hours
  effortActual    Float?   // Person-hours
  
  // Relations
  milestones      Milestone[]
  tasks           Task[]
  decisions       Decision[]
  risks           Risk[]
  artifacts       Artifact[]
  
  // Project Memory
  memory          Json?    // Persistent project knowledge
  
  // Metadata
  isArchived      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?
  
  @@index([portfolioId, state, isArchived])
  @@index([state])
  @@index([slug])
  @@index([plannedEnd])  // For deadline tracking
  @@map("projects")
}

enum ProjectState {
  PROPOSED
  APPROVED
  PLANNING
  EXECUTING
  BLOCKED
  AWAITING_REVIEW
  DEPLOYING
  MONITORING
  COMPLETED
  ROLLBACK
  FAILED
  ARCHIVED
}

// ─────────────────────────────────────────────────────────────────────────────
// MILESTONE - Outcome checkpoint within a project
// ─────────────────────────────────────────────────────────────────────────────

model Milestone {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  name            String
  description     String?  @db.Text
  slug            String
  
  // Sequencing
  sequence        Int
  dependencies    String[] // Array of milestone IDs
  
  // State
  state           MilestoneState @default(PLANNED)
  
  // Timeline
  plannedDate     DateTime?
  actualDate      DateTime?
  
  // Completion criteria
  acceptanceCriteria Json?  // What defines completion
  
  // Relations
  tasks           Task[]
  
  // Metadata
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([projectId, slug])
  @@index([projectId, state])
  @@index([state])
  @@index([plannedDate])
  @@map("milestones")
}

enum MilestoneState {
  PLANNED
  IN_PROGRESS
  COMPLETE
  BLOCKED
  SKIPPED
}

// ─────────────────────────────────────────────────────────────────────────────
// TASK - Smallest executable work unit
// ─────────────────────────────────────────────────────────────────────────────

model Task {
  id                  String   @id @default(cuid())
  number              Int      @default(autoincrement())
  
  // Hierarchy
  projectId           String
  project             Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestoneId         String?
  milestone           Milestone? @relation(fields: [milestoneId], references: [id])
  parentId            String?
  parent              Task?    @relation("Subtasks", fields: [parentId], references: [id])
  subtasks            Task[]   @relation("Subtasks")
  
  // Classification
  title               String
  description         String   @db.Text
  type                TaskType
  priority            TaskPriority @default(MEDIUM)
  tags                String[] // For filtering and categorization
  
  // State Machine (Strict)
  status              TaskStatus @default(QUEUED)
  statusHistory       Json?    // Array of {status, timestamp, actor, reason, metadata}
  
  // Dependencies
  dependencies        String[] // Array of task IDs that must complete first
  dependents          String[] // Array of task IDs that depend on this
  
  // Assignment
  requiredRole        String?  // Agent role required (e.g., "TRADING_LEAD")
  assigneeId          String?
  assignee            Agent?   @relation("AssignedTasks", fields: [assigneeId], references: [id])
  
  // Execution
  requiredTools       String[] // Tools needed (e.g., ["github", "aws", "discord"])
  estimatedEffort     Float?   // Hours
  actualEffort        Float?   // Hours spent
  
  // Timing
  queuedAt            DateTime?
  readyAt             DateTime?
  assignedAt          DateTime?
  startedAt           DateTime?
  completedAt         DateTime?
  dueDate             DateTime?
  
  // Time tracking
  timeLogs            TimeLog[] // Detailed time entries
  
  // Outputs & Validation
  outputs             Json?    // Expected artifacts
  validationCriteria  Json?    // Acceptance criteria
  actualOutputs       Json?    // Produced artifacts
  
  // Retry & Escalation
  retryCount          Int      @default(0)
  maxRetries          Int      @default(3)
  retryRules          Json?    // Retry policy
  escalationPolicy    Json?    // When/how to escalate
  
  // Blocker Tracking
  blockerType         BlockerType?
  blockerReason       String?  @db.Text
  blockerResolvedAt   DateTime?
  blockerResolution   String?  @db.Text  // How it was resolved
  
  // Relations
  comments            TaskComment[]
  attachments         Attachment[]
  
  // External Links
  discordThreadUrl    String?
  githubPrUrl         String?
  githubIssueUrl      String?
  
  // Soft delete
  deletedAt           DateTime?
  isDeleted           Boolean  @default(false)
  
  // Metadata
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdBy           String?
  
  @@index([projectId, status, priority])
  @@index([assigneeId, status])
  @@index([milestoneId, status])
  @@index([status, blockerType])
  @@index([dueDate])  // For deadline alerts
  @@index([isDeleted])
  @@index([type, status])  // For workload balancing
  @@map("tasks")
}

enum TaskType {
  FEATURE
  BUG
  TRADING_STRATEGY
  INFRASTRUCTURE
  SECURITY
  RESEARCH
  DOCUMENTATION
  DEPLOYMENT
  ANALYSIS
  COORDINATION
  TESTING
  CODE_REVIEW
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  QUEUED
  READY
  ASSIGNED
  RUNNING
  AWAITING_DEPENDENCY
  AWAITING_VALIDATION
  BLOCKED
  FAILED
  COMPLETE
  CANCELED
}

enum BlockerType {
  DEPENDENCY_UNMET
  HUMAN_APPROVAL_PENDING
  MISSING_CREDENTIALS
  FAILING_TESTS
  INFRA_UNAVAILABLE
  AMBIGUOUS_REQUIREMENTS
  RISK_THRESHOLD_EXCEEDED
  EXTERNAL_DEPENDENCY
  RESOURCE_UNAVAILABLE
}

// Time tracking for detailed effort analysis
model TimeLog {
  id          String   @id @default(cuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  agentId     String
  startedAt   DateTime
  endedAt     DateTime?
  duration    Float?   // Hours
  
  description String?  // What was done
  
  createdAt   DateTime @default(now())
  
  @@index([taskId, startedAt])
  @@index([agentId])
  @@map("time_logs")
}

model TaskComment {
  id          String @id @default(cuid())
  taskId      String
  task        Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  authorType  CommentAuthorType
  authorId    String?  // Agent ID or User ID
  authorName  String
  content     String   @db.Text
  
  // For threaded comments
  parentId    String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([taskId, createdAt])
  @@map("task_comments")
}

enum CommentAuthorType {
  AGENT
  HUMAN
  SYSTEM
}

model Attachment {
  id          String @id @default(cuid())
  taskId      String
  task        Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  name        String
  filename    String
  url         String
  mimeType    String
  size        Int      // bytes
  
  // Storage info
  storageProvider String @default("s3")  // s3, gcs, azure, etc.
  storageKey      String?
  
  createdAt   DateTime @default(now())
  
  @@index([taskId])
  @@map("attachments")
}

// ─────────────────────────────────────────────────────────────────────────────
// AGENT - Worker profile
// ─────────────────────────────────────────────────────────────────────────────

model Agent {
  id              String   @id @default(cuid())
  handle          String   @unique // @claw-captain, @claw-trader, etc.
  name            String
  role            AgentRole
  avatar          String?  // URL to avatar image
  
  // Configuration
  model           String   // kimi-coding/k2p5, etc.
  apiKeyRef       String   @unique  // Reference to secret, not the actual key
  apiKeyHash      String?  // For validation (bcrypt)
  capabilities    String[] // Array of capability strings
  
  // Trust & Cost
  trustLevel      Float    @default(0.5) // 0-1
  costPerHour     Decimal? @db.Decimal(10, 2)
  
  // Current State
  status          AgentStatus @default(OFFLINE)
  currentLoad     Int      @default(0) // Number of active tasks
  maxLoad         Int      @default(3) // Max concurrent tasks
  
  // Relations
  assignedTasks   Task[]   @relation("AssignedTasks")
  activities      AgentActivity[]
  heartbeats      AgentHeartbeat[]
  timeLogs        TimeLog[]
  
  // Trading-specific
  tradingConfig   TradingConfig?
  
  // Performance History
  performanceStats Json?   // Success rate, avg task time, etc.
  
  // Usage limits
  dailyTaskLimit  Int      @default(10)
  tasksToday      Int      @default(0)
  lastTaskDate    DateTime?
  
  // Metadata
  lastSeenAt      DateTime?
  lastIpAddress   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  isActive        Boolean  @default(true)
  
  @@index([status])
  @@index([role])
  @@index([handle])
  @@index([apiKeyRef])
  @@map("agents")
}

enum AgentRole {
  COORDINATOR
  TRADING_LEAD
  FULLSTACK_DEV
  INFRASTRUCTURE
  SECURITY_QA
  RESEARCHER
  CUSTOM
}

enum AgentStatus {
  ONLINE
  BUSY
  AWAY
  OFFLINE
  ERROR
  DISABLED
}

model AgentHeartbeat {
  id                String   @id @default(cuid())
  agentId           String
  agent             Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  
  timestamp         DateTime @default(now())
  cpuUsage          Float?   // 0-100
  memoryUsage       Float?   // MB
  activeTaskCount   Int      @default(0)
  
  // Extended metrics
  networkLatency    Float?   // ms to Mission Control
  diskUsage         Float?   // Percentage
  
  metadata          Json?    // Flexible extra data
  
  @@index([agentId, timestamp])
  @@map("agent_heartbeats")
}

model AgentActivity {
  id          String   @id @default(cuid())
  agentId     String
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  
  type        ActivityType
  description String
  taskId      String?
  projectId   String?
  metadata    Json?
  
  // Performance tracking
  durationMs  Int?     // How long the activity took
  success     Boolean? // Whether it succeeded
  
  createdAt   DateTime @default(now())
  
  @@index([agentId, createdAt])
  @@index([type])
  @@index([projectId])
  @@index([createdAt])  // For activity feeds
  @@map("agent_activities")
}

enum ActivityType {
  TASK_CREATED
  TASK_ASSIGNED
  TASK_STARTED
  TASK_COMPLETED
  TASK_BLOCKED
  TASK_FAILED
  TASK_RETRY
  CODE_PUSHED
  PR_OPENED
  PR_MERGED
  PR_REVIEWED
  DEPLOYMENT_STARTED
  DEPLOYMENT_COMPLETED
  DEPLOYMENT_FAILED
  TRADE_EXECUTED
  TRADE_CLOSED
  TRADE_FAILED
  ALERT_TRIGGERED
  MESSAGE_SENT
  ERROR_OCCURRED
  DECISION_MADE
  ESCALATION_TRIGGERED
  BLOCKER_RESOLVED
}

// ─────────────────────────────────────────────────────────────────────────────
// TRADING - Specialized configuration for trading agents
// ─────────────────────────────────────────────────────────────────────────────

model TradingConfig {
  id          String @id @default(cuid())
  agentId     String @unique
  agent       Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  
  // Risk limits
  maxPositionSize     Decimal? @db.Decimal(16, 8)
  maxDailyLoss        Decimal? @db.Decimal(10, 2)
  maxDrawdown         Float?   // Percentage
  maxOrdersPerMinute  Int      @default(10)
  maxOpenPositions    Int      @default(5)
  maxLeverage         Int      @default(3)
  
  // Trading permissions
  canTradeLive        Boolean @default(false)
  canTradePaper       Boolean @default(true)
  allowedExchanges    String[]
  allowedPairs        String[] // BTC/USDT, ETH/USDT, etc.
  restrictedHours     Json?    // Times when trading not allowed
  
  // Safety
  killSwitchEnabled   Boolean @default(false)
  lastKillSwitchAt    DateTime?
  killSwitchReason    String?
  
  // Circuit breakers
  dailyLossLimit      Decimal? @db.Decimal(10, 2)
  dailyLossCurrent    Decimal  @default(0) @db.Decimal(10, 2)
  lastResetDate       DateTime @default(now())
  
  updatedAt           DateTime @updatedAt
  
  @@map("trading_configs")
}

model Position {
  id            String @id @default(cuid())
  
  agentId       String
  projectId     String?
  exchange      String
  symbol        String // BTC/USDT
  side          PositionSide
  
  entryPrice    Decimal @db.Decimal(16, 8)
  size          Decimal @db.Decimal(16, 8)
  leverage      Int     @default(1)
  
  // P&L tracking
  unrealizedPnl Decimal? @db.Decimal(16, 8)
  realizedPnl   Decimal? @db.Decimal(16, 8)
  pnlPercent    Float?   // Percentage
  
  // Risk
  stopLoss      Decimal? @db.Decimal(16, 8)
  takeProfit    Decimal? @db.Decimal(16, 8)
  
  status        PositionStatus @default(OPEN)
  openedAt      DateTime @default(now())
  closedAt      DateTime?
  
  // Strategy tracking
  strategyId    String?
  taskId        String?
  
  // Relations
  orders        Order[]
  
  @@index([agentId, status])
  @@index([symbol, status])
  @@index([projectId])
  @@index([openedAt])  // For P&L calculations
  @@map("positions")
}

enum PositionSide {
  LONG
  SHORT
}

enum PositionStatus {
  OPEN
  CLOSED
  LIQUIDATED
  STOPPED
  EXPIRED
}

model Order {
  id          String @id @default(cuid())
  
  positionId  String?
  position    Position? @relation(fields: [positionId], references: [id])
  
  agentId     String
  projectId   String?
  exchange    String
  symbol      String
  externalId  String?  // Exchange's order ID
  
  side        OrderSide
  type        OrderType
  status      OrderStatus @default(PENDING)
  
  size        Decimal @db.Decimal(16, 8)
  price       Decimal? @db.Decimal(16, 8) // Null for market orders
  
  // Execution
  executedSize  Decimal? @db.Decimal(16, 8)
  executedPrice Decimal? @db.Decimal(16, 8)
  fees          Decimal? @db.Decimal(16, 8)
  
  // Metadata
  strategyId    String? // Link to strategy that generated this
  taskId        String? // Link to originating task
  metadata      Json?   // Strategy-specific data
  
  // Error tracking
  errorMessage  String?
  retryCount    Int     @default(0)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([agentId, status])
  @@index([projectId])
  @@index([createdAt])
  @@index([exchange, externalId])
  @@map("orders")
}

enum OrderSide {
  BUY
  SELL
}

enum OrderType {
  MARKET
  LIMIT
  STOP_LOSS
  TAKE_PROFIT
  STOP_LOSS_LIMIT
  TAKE_PROFIT_LIMIT
  TRAILING_STOP
}

enum OrderStatus {
  PENDING
  OPEN
  PARTIALLY_FILLED
  FILLED
  CANCELLED
  REJECTED
  EXPIRED
  FAILED
}

// ─────────────────────────────────────────────────────────────────────────────
// DECISION - Explicit recorded judgments
// ─────────────────────────────────────────────────────────────────────────────

model Decision {
  id            String @id @default(cuid())
  projectId     String
  project       Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  title         String
  description   String @db.Text
  rationale     String @db.Text
  
  authorType    CommentAuthorType
  authorId      String?
  authorName    String
  
  // Approvals
  requiredApprovals Int @default(0)
  currentApprovals  Int @default(0)
  approvals     Json? // Array of {approver, timestamp, comment}
  
  // State
  state         DecisionState @default(PROPOSED)
  
  // Related items
  relatedTaskIds String[]
  tags          String[]
  
  createdAt     DateTime @default(now())
  resolvedAt    DateTime?
  
  @@index([projectId, state])
  @@index([state])
  @@index([createdAt])
  @@map("decisions")
}

enum DecisionState {
  PROPOSED
  UNDER_REVIEW
  APPROVED
  REJECTED
  SUPERSEDED
  IMPLEMENTED
}

// ─────────────────────────────────────────────────────────────────────────────
// RISK - Tracked threats
// ─────────────────────────────────────────────────────────────────────────────

model Risk {
  id            String @id @default(cuid())
  projectId     String
  project       Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  title         String
  description   String @db.Text
  category      RiskCategory @default(TECHNICAL)
  
  // Risk assessment
  likelihood    RiskLevel
  impact        RiskLevel
  score         Int      // Calculated: likelihood * impact
  
  // Mitigation
  mitigation    String?  @db.Text
  contingency   String?  @db.Text  // Plan B if risk materializes
  owner         String?  // Agent or human responsible
  
  // State
  status        RiskStatus @default(IDENTIFIED)
  
  // Tracking
  identifiedAt  DateTime @default(now())
  resolvedAt    DateTime?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([projectId, status])
  @@index([score])
  @@index([category])
  @@map("risks")
}

enum RiskCategory {
  TECHNICAL
  SCHEDULE
  BUDGET
  SECURITY
  LEGAL
  EXTERNAL
  OPERATIONAL
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskStatus {
  IDENTIFIED
  ASSESSING
  MITIGATING
  MONITORING
  ACCEPTED
  RESOLVED
  REALIZED  // Actually happened
}

// ─────────────────────────────────────────────────────────────────────────────
// ARTIFACT - Outputs produced by tasks
// ─────────────────────────────────────────────────────────────────────────────

model Artifact {
  id            String @id @default(cuid())
  
  projectId     String
  project       Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId        String?
  task          Task?   @relation(fields: [taskId], references: [id])
  
  type          ArtifactType
  name          String
  description   String? @db.Text
  url           String
  
  // For code artifacts
  githubRepo    String?
  githubPr      String?
  githubCommit  String?
  
  // For deployed artifacts
  environment   String? // staging, production
  version       String?
  
  // For file artifacts
  fileSize      Int?
  mimeType      String?
  
  // Validation
  validated     Boolean @default(false)
  validatedAt   DateTime?
  validatedBy   String?
  validationResult Json?  // Test results, scan reports, etc.
  
  metadata      Json?   // Flexible metadata
  
  createdAt     DateTime @default(now())
  createdBy     String?
  
  @@index([projectId, type])
  @@index([taskId])
  @@index([createdAt])
  @@index([type, validated])  // For finding unvalidated artifacts
  @@map("artifacts")
}

enum ArtifactType {
  SPECIFICATION
  DESIGN
  CODE
  PR
  DEPLOYMENT
  TEST_RESULT
  DOCUMENTATION
  REPORT
  DATA_EXPORT
  DECISION_RECORD
  CONFIGURATION
}

// ─────────────────────────────────────────────────────────────────────────────
// AUDIT - Immutable action log
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id            String @id @default(cuid())
  
  timestamp     DateTime @default(now())
  actorType     ActorType
  actorId       String?  // Agent ID or User ID
  actorName     String
  
  action        String   // What happened
  resourceType  String   // Task, Project, Position, etc.
  resourceId    String?
  
  beforeState   Json?    // Previous state
  afterState    Json?    // New state
  
  // Request context
  ipAddress     String?
  userAgent     String?
  requestId     String?  // For tracing
  
  severity      AuditSeverity @default(INFO)
  
  // Soft delete protection
  isDeleted     Boolean @default(false)
  
  @@index([timestamp])
  @@index([actorId])
  @@index([resourceType, resourceId])
  @@index([severity])
  @@index([action])
  @@index([timestamp, actorId])  // For user activity
  @@map("audit_logs")
}

enum ActorType {
  AGENT
  HUMAN
  SYSTEM
  WEBHOOK
  SCHEDULER
}

enum AuditSeverity {
  DEBUG
  INFO
  WARNING
  ERROR
  CRITICAL
  SECURITY
}

// ─────────────────────────────────────────────────────────────────────────────
// SYSTEM - Configuration and operational state
// ─────────────────────────────────────────────────────────────────────────────

model SystemConfig {
  id          String @id @default(cuid())
  key         String @unique
  value       Json
  description String?
  category    String @default("general")  // general, trading, security, etc.
  isSecret    Boolean @default(false)     // Mask in UI/logs
  updatedAt   DateTime @updatedAt
  updatedBy   String?
  
  @@index([category])
  @@map("system_config")
}

model Webhook {
  id          String @id @default(cuid())
  
  name        String
  url         String
  secret      String   // For signature verification
  
  eventTypes  String[] // Which events to send
  
  // Status
  isActive    Boolean @default(true)
  lastUsedAt  DateTime?
  lastError   String?
  failCount   Int @default(0)
  successCount Int @default(0)
  
  // Retry config
  maxRetries  Int @default(3)
  
  createdAt   DateTime @default(now())
  
  @@index([isActive])
  @@map("webhooks")
}

// Event store for event sourcing pattern
model Event {
  id            String   @id @default(cuid())
  
  type          String   // Event type
  aggregateType String   // Project, Task, etc.
  aggregateId   String   // ID of the aggregate
  
  payload       Json     // Event data
  metadata      Json?    // Correlation ID, causation ID, etc.
  
  actorType     ActorType
  actorId       String?
  
  // Versioning for optimistic concurrency
  version       Int      @default(1)
  
  timestamp     DateTime @default(now())
  
  @@index([aggregateType, aggregateId])
  @@index([type])
  @@index([timestamp])
  @@index([aggregateType, timestamp])  // For replay
  @@map("events")
}

// Health checks and system monitoring
model HealthCheck {
  id            String   @id @default(cuid())
  
  service       String   // api, database, discord, etc.
  status        String   // healthy, degraded, down
  responseTime  Int?     // ms
  message       String?
  details       Json?
  
  checkedAt     DateTime @default(now())
  
  @@index([service, checkedAt])
  @@index([status])
  @@map("health_checks")
}

// Notifications to agents/humans
model Notification {
  id            String   @id @default(cuid())
  
  recipientType String   // AGENT, HUMAN, CHANNEL
  recipientId   String   // agent ID, user ID, or channel name
  
  type          String   // TASK_ASSIGNED, BLOCKER, KILL_SWITCH, etc.
  title         String
  message       String   @db.Text
  
  // Delivery
  channel       String   // discord, email, in_app, etc.
  deliveredAt   DateTime?
  readAt        DateTime?
  
  // Related entities
  taskId        String?
  projectId     String?
  
  createdAt     DateTime @default(now())
  
  @@index([recipientId, readAt])
  @@index([createdAt])
  @@map("notifications")
}
