# Mission Control - Environment Variables
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to git!

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Get from: Supabase Dashboard > Settings > Database > Connection string
# Or use local PostgreSQL: postgresql://postgres:postgres@localhost:5432/mission_control
DATABASE_URL=postgresql://your_user:your_password@your_host:5432/your_database

# =============================================================================
# NextAuth.js Authentication
# =============================================================================
# Generate a random string (at least 32 characters):
#   Linux/Mac: openssl rand -base64 32
#   Or use: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=your_random_secret_here_at_least_32_chars

# Your app's base URL
# Development: http://localhost:3000
# Production: https://your-domain.vercel.app
NEXTAUTH_URL=http://localhost:3000

# =============================================================================
# GitHub OAuth (for NextAuth)
# =============================================================================
# 1. Go to https://github.com/settings/developers
# 2. Click "New OAuth App"
# 3. Set Authorization callback URL: ${NEXTAUTH_URL}/api/auth/callback/github
# 4. Copy Client ID and generate a Client Secret
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# =============================================================================
# Discord Bot
# =============================================================================
# 1. Go to https://discord.com/developers/applications
# 2. Create New Application → Bot → Add Bot
# 3. Enable Privileged Intents: SERVER MEMBERS, MESSAGE CONTENT
# 4. Copy Token (reset if needed)
# 5. Invite bot to your server with scopes: bot, applications.commands
#    Permissions: Send Messages, Read Message History, Embed Links, etc.
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Discord Webhook URL for system notifications
# Create in your Discord server: Channel Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Guild ID of your Discord server (for slash commands)
# Right-click your server → Copy Server ID (enable Developer Mode in Discord settings)
DISCORD_GUILD_ID=your_discord_server_id

# =============================================================================
# GitHub Personal Access Token (PAT)
# =============================================================================
# For API access to repos, issues, PRs
# 1. Go to https://github.com/settings/tokens
# 2. Generate new token (classic) with scopes:
#    - repo (Full control of private repositories)
#    - read:org (Read org and team membership)
#    - read:user (Read user profile data)
GITHUB_PAT=ghp_your_personal_access_token_here

# =============================================================================
# Optional: Trading Configuration
# =============================================================================
# If using trading features, add your exchange API credentials
# Example for Hyperliquid (adjust for your exchange):
# HYPERLIQUID_API_KEY=your_api_key
# HYPERLIQUID_API_SECRET=your_api_secret
# HYPERLIQUID_TESTNET=true

# =============================================================================
# Optional: Monitoring & Analytics
# =============================================================================
# For error tracking (Sentry, etc.)
# SENTRY_DSN=your_sentry_dsn

# For analytics (Plausible, Google Analytics, etc.)
# ANALYTICS_ID=your_analytics_id
